{
  "name": "vitre-css",
  "version": "1.1.1",
  "description": "Classless CSS with a high-end glass finish for semantic HTML.",
  "license": "MIT",
  "homepage": "https://appurist.github.io/vitre-css/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/appurist/vitre-css.git"
  },
  "bugs": {
    "url": "https://github.com/appurist/vitre-css/issues"
  },
  "directories": {
    "doc": "docs"
  },
  "keywords": [
    "css",
    "classless",
    "semantic-html",
    "stylesheet",
    "theme",
    "dark-mode"
  ],
  "main": "vitre.css",
  "style": "vitre.css",
  "unpkg": "vitre.css",
  "jsdelivr": "vitre.css",
  "files": [
    "vitre.css",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "check": "npm pack --dry-run",
    "docs": "node -e \"const fs=require('fs'); fs.copyFileSync('vitre.css','docs/vitre.css'); fs.copyFileSync('test.html','docs/test.html'); fs.mkdirSync('docs/media',{recursive:true}); fs.copyFileSync('media/september.mp3','docs/media/september.mp3'); fs.copyFileSync('media/drowning-in-life-clip.mp4','docs/media/drowning-in-life-clip.mp4')\"",
    "release": "npm publish --access public"
  }
}
